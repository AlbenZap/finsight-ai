# ── LLM Provider ──────────────────────────────────────────────────────────────
# "ollama": self-hosted Llama 3.1 8B model via Ollama
# "nvidia_nim": NVIDIA NIM cloud API (free tier, 40 RPM)
LLM_PROVIDER=nvidia_nim

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_MODEL=llama3.1:8b
# OLLAMA_BASE_URL=http://ollama:11434   # only needed to override default

# ── NVIDIA NIM ────────────────────────────────────────────────────────────────
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxx
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# ── SEC EDGAR Identity ────────────────────────────────────────────────────────
SEC_IDENTITY=name name@email.com

# ── HuggingFace ───────────────────────────────────────────────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
HF_DATASET_REPO=name/finsight-ai-store

# ── LangSmith Observability ───────────────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_xxxxxxxxxxxxxxxxxxxx
# LANGCHAIN_PROJECT=finsight-ai

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# FRONTEND_URL=http://localhost:3000,https://finsight-ai-sec.vercel.app

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:8000
# VITE_BACKEND_URL=https://name-finsight-ai.hf.space